# BLE Lost Device Finder Configuration
# Copy this file to .env and fill in your device details.

# Comma-separated list of BLE MAC addresses to track.
# Example: TARGET_ADDRESSES=AA:BB:CC:DD:EE:FF,11:22:33:44:55:66
TARGET_ADDRESSES=

# Comma-separated list of names (or partial names) to match.
# Example: TARGET_NAMES=AirPods,Galaxy Buds
TARGET_NAMES=

# Optional: Reference RSSI at 1 meter (default: -59)
# REFERENCE_RSSI=-59

# Optional: Path loss exponent (default: 2.2)
# PATH_LOSS_EXPONENT=2.2
